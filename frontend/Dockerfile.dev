FROM node:22-alpine

# wget needed for HEALTHCHECK
RUN apk add --no-cache wget

WORKDIR /app

# Copy only package files first for dependency caching
COPY package.json package-lock.json ./
RUN npm install

# Source files are mounted via docker-compose.dev.yml volumes for hot reload
# Dockerfile.dev produces the base image with node_modules baked in

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 \
    CMD wget -qO- http://localhost:80/ || exit 1

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "80"]
