# Environment
NODE_ENV=development

# Server
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/user_service

# JWT
JWT_SECRET=replace-with-a-secure-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1h

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
