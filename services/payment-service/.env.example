# Service-specific config (copy to .env for standalone dev)
NODE_ENV=development
PORT=3004
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_service
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_PROCESSING_DELAY_MS=2000
CORS_ORIGIN=*
LOG_LEVEL=info

