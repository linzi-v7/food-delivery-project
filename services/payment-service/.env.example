# Environment
NODE_ENV=development

# Server
PORT=3004

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_service

# Order Service (for order validation + status callbacks)
ORDER_SERVICE_URL=http://order-service:3003

# Payment Simulation
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_PROCESSING_DELAY_MS=2000

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
