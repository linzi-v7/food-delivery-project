# Environment
NODE_ENV=development

# Server
PORT=3003

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_service

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# User Service (for customer validation)
USER_SERVICE_URL=http://user-service:3001

# Restaurant Service (for restaurant + menu validation)
RESTAURANT_SERVICE_URL=http://restaurant-service:3002

# Payment Service (for payment initiation after order creation)
PAYMENT_SERVICE_URL=http://payment-service:3004
