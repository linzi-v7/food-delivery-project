# Service-specific config (copy to .env for standalone dev)
NODE_ENV=development
PORT=3003
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_service
CORS_ORIGIN=*
LOG_LEVEL=info

# Shared config — set ONCE in root .env, injected by docker-compose
