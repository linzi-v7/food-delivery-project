# =============================================================================
# Food Delivery System -- Root Environment Variables
# =============================================================================
# ONE file to rule them all. Copy to .env before starting:
#   cp .env.example .env
#
# Shared secrets and inter-service URLs live HERE.
# Per-service files (services/*/.env) only hold service-specific config.
# docker-compose.yml injects these into containers via `environment:` blocks.
# =============================================================================

# -- Database (shared by all services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -- Auth (injected into user-service + order-service)
JWT_SECRET=k/RtkF/MlTchfASGyHwq+ZP1zfx2IDRElCHYFJK/fxjlrh1xeTVt+C4Dqi/QqQOv
JWT_EXPIRES_IN=1h

# -- Password Hashing (injected into user-service)
BCRYPT_SALT_ROUNDS=10

# -- Inter-Service URLs (injected into order-service + payment-service)
USER_SERVICE_URL=http://user-service:3001
RESTAURANT_SERVICE_URL=http://restaurant-service:3002
ORDER_SERVICE_URL=http://order-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3004

# -- Payment Simulation (injected into payment-service)
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_PROCESSING_DELAY_MS=2000

# -- Frontend (build-time arg)
VITE_API_URL=http://localhost:8080/api

# -- Global Defaults
NODE_ENV=development
CORS_ORIGIN=*
LOG_LEVEL=debug
